      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst rows = $input.all();\nconst existingWords = rows\n  .map(r => r.json[\"Word/Phrase\"])\n  .filter(Boolean)\n  .map(w => w.toLowerCase().trim());\nreturn [{ json: { existingWords: existingWords.length ? existingWords : [] } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
