    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n// get all rows from sheet\nconst rows = $input.all().map(i => i.json);\n\n// remove blank spacer rows\nconst filtered = rows.filter(r => r[\"Word/Phrase\"]);\n\n// take the newest 5 vocab rows\nconst lastFive = filtered.slice(-5);\n\n// build formatted email body\nconst formattedMessage = `\n<h2>Good morning Shadae! Here's your daily vocab list:</h2>\n\n${lastFive.map((row, i) => `\n<p>\n<b>${i + 1}. ${row[\"Word/Phrase\"]} (${row[\"Difficulty\"]})</b><br>\nMeaning: ${row[\"Translation\"]}<br>\nExample: ${row[\"Example (DE)\"]}\n</p>\n`).join(\"\")}\n`;\n\nreturn [\n  {\n    json: {\n      emailBody: formattedMessage\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
